function validParentheses(parenStr) {
  let balance = 0;

  for (let i = 0; i < parenStr.length; i++) {
    const char = parenStr[i];

    if (char === '(') {
      balance++;
    } else if (char === ')') {
      balance--;
    }

    if (balance < 0) {
      return false;
    }
  }

  return balance === 0;
}
